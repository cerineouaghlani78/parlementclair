{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "auth-shell.jsx",
              "dashboard.jsx",
              "data.js",
              "design-canvas.jsx",
              "design_handoff_opendaw_design_system/ui_kits/studio/**",
              "home-variant-a.jsx",
              "icons.jsx",
              "landing.jsx",
              "login.jsx",
              "primitives.jsx",
              "samples.jsx",
              "sessions.jsx",
              "signup.jsx",
              "studio-icons.jsx",
              "studio.jsx",
              "ui_kits/studio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Rubik|Open Sans))/i]",
        "message": "Font not provided by the design system. Available: Rubik, Open Sans."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--bg-app",
      "--bg-card",
      "--bg-elevated",
      "--bg-panel",
      "--bg-panel-2",
      "--color-active",
      "--color-active-parent",
      "--color-black",
      "--color-blue",
      "--color-bright",
      "--color-cyan",
      "--color-dark",
      "--color-gray",
      "--color-green",
      "--color-orange",
      "--color-purple",
      "--color-red",
      "--color-shadow",
      "--color-void",
      "--color-yellow",
      "--fg1",
      "--fg2",
      "--fg3",
      "--font-body",
      "--font-display",
      "--font-mono",
      "--fs-10",
      "--fs-11",
      "--fs-12",
      "--fs-13",
      "--fs-14",
      "--fs-18",
      "--fs-22",
      "--fs-36",
      "--gap-1",
      "--gap-2",
      "--gap-3",
      "--gap-4",
      "--gap-6",
      "--glow-active",
      "--glow-frame",
      "--line-faint",
      "--line-hover",
      "--line-soft",
      "--radius-1",
      "--radius-2",
      "--radius-3",
      "--radius-4",
      "--shadow-floating"
    ],
    "tokenKinds": {
      "--color-blue": "color",
      "--color-green": "color",
      "--color-orange": "color",
