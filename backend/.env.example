# Copiez ce fichier en `.env` et adaptez les valeurs.

# API compatible OpenAI. Par défaut : Groq (cloud, gratuit) avec Llama 3.3 —
# clé à récupérer sur https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=

# Pour repasser sur un serveur vLLM local (cf. PROJET.md) à la place de Groq :
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=qwen3.5
# LLM_API_KEY=EMPTY

# Serveur MCP Tricoteuses (base législative)
MCP_URL=https://mcp.code4code.eu/mcp

# Persistance SQLite
DB_PATH=./data/lexclair.db

# Origines autorisées pour le front-end (CSV géré via python-dotenv -> liste)
CORS_ORIGINS=["http://localhost:5173"]
